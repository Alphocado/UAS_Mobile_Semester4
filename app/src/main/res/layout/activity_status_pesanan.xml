<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/page_status_pesanan"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/header_status"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:background="@drawable/bg_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <TextView
            android:id="@+id/btn_back_status"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_nav_active"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/blue_700"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_status_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Alur Status"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Pending → Diproses → Selesai"
                android:textColor="@color/blue_100"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_status"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="18dp"
        android:paddingTop="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:id="@+id/card_status_timeline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tv_status_card_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Timeline Status Pesanan"
                android:textColor="@color/dark_900"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_pending_circle"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_chip_pending"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/yellow_700"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status_pending_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Pending"
                android:textColor="@color/dark_900"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status_pending_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Pesanan baru masuk dan menunggu konfirmasi admin."
                android:textColor="@color/dark_700"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/status_process_circle"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_chip_process"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/orange_700"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status_process_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Diproses"
                android:textColor="@color/dark_900"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status_process_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Pesanan sedang disiapkan oleh tenant."
                android:textColor="@color/dark_700"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/status_done_circle"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_chip_done"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/green_700"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status_done_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Selesai"
                android:textColor="@color/dark_900"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status_done_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Pesanan selesai dan siap diambil pengguna."
                android:textColor="@color/dark_700"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_status_back_to_orders"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_primary_button"
                android:gravity="center"
                android:text="Kembali ke Pesanan"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>