<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/page_tenant_profile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/toolbar_tenant_profile"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="18dp"
        android:paddingRight="18dp">

        <TextView
            android:id="@+id/btn_back_profile"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="Back"
            android:textColor="@color/dark_900"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_profile_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Profil"
            android:textColor="@color/dark_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="42dp"
            android:layout_height="42dp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_tenant_profile"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:id="@+id/container_tenant_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/avatar_tenant_profile"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:text="BW"
                android:textColor="@color/gray_400"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_profile_stand_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Stand Bu Warsi"
                android:textColor="@color/dark_900"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_profile_stand_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Stand ID: ST-001"
                android:textColor="@color/dark_700"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/profile_form_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/label_profile_stand_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nama Stand"
                    android:textColor="@color/dark_900"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_profile_stand_name"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:inputType="text"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:singleLine="true"
                    android:text="Stand Bu Warsi"
                    android:textColor="@color/dark_900"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/label_profile_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Email"
                    android:textColor="@color/dark_900"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_profile_email"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:inputType="textEmailAddress"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:singleLine="true"
                    android:text="buwarsi@foodcourtgo.com"
                    android:textColor="@color/dark_900"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/label_profile_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="No. Telepon"
                    android:textColor="@color/dark_900"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_profile_phone"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:inputType="phone"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:singleLine="true"
                    android:text="0812-3456-7890"
                    android:textColor="@color/dark_900"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/label_profile_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Lokasi Stand"
                    android:textColor="@color/dark_900"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_profile_location"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:inputType="text"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:singleLine="true"
                    android:text="Food Court UNM Lantai 1"
                    android:textColor="@color/dark_900"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_save_profile"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_primary_button"
                android:gravity="center"
                android:text="Simpan Perubahan"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>