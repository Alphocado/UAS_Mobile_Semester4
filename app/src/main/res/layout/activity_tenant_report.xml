<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/page_tenant_report"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/toolbar_tenant_report"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="18dp"
        android:paddingRight="18dp">

        <TextView
            android:id="@+id/btn_back_report"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="Back"
            android:textColor="@color/dark_900"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_report_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Laporan"
            android:textColor="@color/dark_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="42dp"
            android:layout_height="42dp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_tenant_report"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:id="@+id/container_tenant_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/report_filter_row"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/filter_report_period"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginRight="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:text="Bulan Ini"
                    android:textColor="@color/dark_900"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/filter_report_month"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginLeft="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:text="Mei 2024"
                    android:textColor="@color/dark_900"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_report_chart"
                android:layout_width="match_parent"
                android:layout_height="286dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_report_chart_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Grafik Penjualan"
                    android:textColor="@color/dark_900"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/chart_sales_container"
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:layout_marginTop="18dp"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/bar_report_1"
                        android:layout_width="0dp"
                        android:layout_height="82dp"
                        android:layout_marginLeft="5dp"
                        android:layout_marginRight="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chart_bar_soft" />

                    <View
                        android:id="@+id/bar_report_2"
                        android:layout_width="0dp"
                        android:layout_height="132dp"
                        android:layout_marginLeft="5dp"
                        android:layout_marginRight="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chart_bar" />

                    <View
                        android:id="@+id/bar_report_3"
                        android:layout_width="0dp"
                        android:layout_height="96dp"
                        android:layout_marginLeft="5dp"
                        android:layout_marginRight="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chart_bar_soft" />

                    <View
                        android:id="@+id/bar_report_4"
                        android:layout_width="0dp"
                        android:layout_height="150dp"
                        android:layout_marginLeft="5dp"
                        android:layout_marginRight="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chart_bar" />

                    <View
                        android:id="@+id/bar_report_5"
                        android:layout_width="0dp"
                        android:layout_height="176dp"
                        android:layout_marginLeft="5dp"
                        android:layout_marginRight="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chart_bar" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_report_chart_labels"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1 Mei        8 Mei        15 Mei        22 Mei        31 Mei"
                    android:textColor="@color/dark_700"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_report_income"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Pendapatan"
                    android:textColor="@color/dark_700"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_report_total_income"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Rp 450.000"
                    android:textColor="@color/dark_900"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_report_order_total"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Pesanan"
                    android:textColor="@color/dark_700"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_report_total_order"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="12"
                    android:textColor="@color/dark_900"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_report_average"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rata - Rata / Hari"
                    android:textColor="@color/dark_700"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_report_daily_average"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Rp 15.000"
                    android:textColor="@color/dark_900"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>